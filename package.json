{
  "name": "capsar-doc-controller",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone ACC document compliance worker; consumes Capsar integration API.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",

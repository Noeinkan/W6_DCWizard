  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "supertest": "^7.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
